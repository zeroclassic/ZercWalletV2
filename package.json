{
  "name": "zerc-wallet",
  "version": "2.0.28",
  "description": "ZeroClassic Desktop Wallet - Full node UI for ZERC",
  "main": "dist/main/main.js",
  "author": {
    "name": "ZeroClassic Community",
    "email": "contact@zeroclassic.org"
  },
  "license": "MIT",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -p tsconfig.main.json --watch",
    "dev": "concurrently -n RENDERER,MAIN -c cyan,yellow \"npm run dev:renderer\" \"npm run dev:main\"",
    "electron:dev": "cross-env NODE_ENV=development ELECTRON_DEV=1 wait-on http://localhost:5173 && electron .",
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build",
    "build": "npm run build:main && npm run build:renderer",
    "start": "npm run build && electron .",
    "pack": "npm run build && electron-builder --dir",
    "dist:win": "npm run build && cross-env CSC_IDENTITY_AUTO_DISCOVERY=false electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux:arm64": "npm run build && electron-builder --linux --arm64"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "qrcode.react": "^3.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@types/react-dom": "^18.0.0",
    "@vitejs/plugin-react": "^4.0.0",
    "concurrently": "^8.0.0",
    "cross-env": "^7.0.3",
    "electron": "^28.0.0",
    "electron-builder": "^23.6.0",
    "react": "^18.0.0",
    "react-dom": "^18.0.0",
    "typescript": "^5.0.0",
    "vite": "^5.0.0",
    "wait-on": "^7.0.0",
    "@types/qrcode.react": "^1.0.5"
  },
  "build": {
    "appId": "org.zeroclassic.wallet",
    "productName": "ZercWallet",
    "copyright": "Copyright \u00a9 2025 ZeroClassic Community",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "resources/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "resources/256x256.png",
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ZercWallet"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "build/icons",
      "category": "Finance",
      "maintainer": "ZeroClassic Community <contact@zeroclassic.org>"
    },
    "mac": {
      "target": "dmg",
      "icon": "resources/icon.icns"
    }
  },
  "homepage": "https://zeroclassic.org",
  "zerc": {
    "targetNode": "ZercNOVA - 5.1.1"
  }
}